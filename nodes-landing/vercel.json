{
  "framework": "astro",
  "redirects": [
    {
      "source": "/auth",
      "destination": "https://www.nodes-tracker.ru/signup",
      "permanent": false
    },
    {
      "source": "/auth/:path*",
      "destination": "https://www.nodes-tracker.ru/auth/:path*",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://www.nodes-tracker.ru/login",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "https://www.nodes-tracker.ru/signup",
      "permanent": false
    },
    {
      "source": "/app/:path*",
      "destination": "https://www.nodes-tracker.ru/:path*",
      "permanent": false
    }
  ]
}
