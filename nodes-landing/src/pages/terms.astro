---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
import en from '../i18n/en.json';
const t = en;
---

<BaseLayout lang={lang}>
  <div class="container mx-auto py-24 px-6 max-w-4xl min-h-[60vh]">
    <div class="mb-12">
      <a href="/" class="text-primary hover:underline inline-flex items-center mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="m15 18-6-6 6-6"/></svg>
        Back to home
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t.footer.legal.termsContent.title}</h1>
      <p class="text-muted-foreground">{t.footer.legal.termsContent.lastUpdated}: {new Date().toLocaleDateString('en-US')}</p>
    </div>

    <div class="prose dark:prose-invert max-w-none">
      {t.footer.legal.termsContent.sections.map((section) => (
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">{section.title}</h2>
          <p class="text-lg text-muted-foreground leading-relaxed">{section.content}</p>
        </section>
      ))}
    </div>
  </div>
  <Footer lang={lang} />
</BaseLayout>
