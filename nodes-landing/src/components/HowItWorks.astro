---
interface Props {
  lang: 'en' | 'ru';
}

const { lang } = Astro.props;

import en from '../i18n/en.json';
import ru from '../i18n/ru.json';
const translations: Record<string, any> = { en, ru };
const t = translations[lang];
---

<section id="how-it-works" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="reveal inline-flex items-center gap-2 rounded-full bg-primary/10 border border-primary/20 px-4 py-1.5 text-sm font-medium text-primary mb-4">
        {t.howItWorks.badge}
      </span>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-5xl font-bold tracking-tighter">
        {t.howItWorks.title}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {t.howItWorks.steps.map((step: any, i: number) => (
        <div class={`reveal card-hover reveal-delay-${i + 1} group relative rounded-2xl border border-border bg-card p-8 hover:border-primary/30`}>
          <span class="text-5xl font-bold text-primary/20 group-hover:text-primary/40 group-hover:scale-110 transition-all duration-500 font-mono">
            {step.number}
          </span>
          <h3 class="text-xl font-semibold mt-4 mb-3">{step.title}</h3>
          <p class="text-muted-foreground leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
