# --- API Keys for Content Recommender ---

# Google Cloud (YouTube & Google Books)
YOUTUBE_API_KEY=your_youtube_api_key_here
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# GitHub (Open Source)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Stepik (Courses)
# Get ID/Secret at: https://stepik.org/oauth2/applications/
STEPIK_CLIENT_ID=your_stepik_id_here
STEPIK_CLIENT_SECRET=your_stepik_secret_here

# Admitad (Affiliate/Monetization)
# Get credentials at: https://www.admitad.com/
ADMITAD_CLIENT_ID=your_admitad_id_here
ADMITAD_CLIENT_SECRET=your_admitad_secret_here
ADMITAD_WEBSITE_ID=your_website_id_here

# --- Database & System ---
DATABASE_URL=your_supabase_postgresql_url
SUPABASE_URL=your_supabase_project_url
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
DEBUG=True
